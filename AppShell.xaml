<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VentasApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:VentasApp.Views"
    Shell.TitleColor="White"
    Shell.BackgroundColor="{StaticResource Primary}"
    Shell.ForegroundColor="White"
    FlyoutBackgroundColor="{StaticResource Gray100}">

    <FlyoutItem Title="Login" FlyoutItemIsVisible="False">
        <ShellContent Route="LoginPage" ContentTemplate="{DataTemplate views:LoginPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Ventas" FlyoutDisplayOptions="AsMultipleItems">
        <ShellContent Title="Dashboard" Route="DashboardPage" ContentTemplate="{DataTemplate views:DashboardPage}" />
        <ShellContent Title="Productos" Route="ProductsPage" ContentTemplate="{DataTemplate views:ProductsPage}" />
        <ShellContent Title="Clientes" Route="CustomersPage" ContentTemplate="{DataTemplate views:CustomersPage}" />
        <ShellContent Title="Toma de Pedido" Route="TakeOrderPage" ContentTemplate="{DataTemplate views:TakeOrderPage}" />
        <ShellContent Title="Control y Fact." Route="OrdersPage" ContentTemplate="{DataTemplate views:OrdersPage}" />
        <ShellContent Title="Preparación/Envío" Route="DeliveryPage" ContentTemplate="{DataTemplate views:DeliveryPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Administración" FlyoutDisplayOptions="AsMultipleItems">
        <ShellContent Title="Vendedores" Route="VendedoresPage" ContentTemplate="{DataTemplate views:VendedoresPage}" />
        <ShellContent Title="Equipos" Route="EquiposPage" ContentTemplate="{DataTemplate views:EquiposPage}" />
    </FlyoutItem>

</Shell>
