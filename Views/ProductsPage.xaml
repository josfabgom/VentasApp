<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:VentasApp.Converters"
             x:Class="VentasApp.Views.ProductsPage"
             Title="{Binding Title}">
             
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:ImagePathConverter x:Key="ImagePathConv" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <RefreshView Command="{Binding LoadProductsCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Products}" 
                            SelectionMode="None"
                            Margin="10">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame CornerRadius="10" 
                               Margin="5,5,5,15" 
                               Padding="15" 
                               HasShadow="True">
                            <StackLayout>
                                <Grid ColumnDefinitions="120, *">
                                    <Image Grid.Column="0" 
                                           Source="{Binding ImageUrl, Converter={StaticResource ImagePathConv}}" 
                                           WidthRequest="100" 
                                           HeightRequest="100" 
                                           Aspect="AspectFill"
                                           Margin="0,0,15,0"
                                           VerticalOptions="Center" />
                                    <StackLayout Grid.Column="1">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="18"/>
                                        <Label Text="{Binding Description}" TextColor="Gray"/>
                                        <Label Text="{Binding Price, StringFormat='Precio: {0:C}'}"/>
                                        <Label Text="{Binding Stock, StringFormat='Stock: {0}'}" TextColor="{StaticResource Primary}"/>
                                        
                                        <!-- Opciones de Codigo/Qr si estan llenas -->
                                        <HorizontalStackLayout Spacing="10" Margin="0,5,0,0">
                                            <Label Text="{Binding Barcode, StringFormat='🏷️: {0}'}" FontSize="12" TextColor="Gray"/>
                                            <Label Text="{Binding QrCode, StringFormat='🔳: {0}'}" FontSize="12" TextColor="Gray"/>
                                        </HorizontalStackLayout>
                                    </StackLayout>
                                </Grid>
                                
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,15,0,0">
                                    <Button Grid.Column="0" 
                                            Text="Editar" 
                                            BackgroundColor="#2E8BC0" 
                                            CornerRadius="5" 
                                            HeightRequest="35"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.EditProductCommand}" 
                                            CommandParameter="{Binding .}"/>
                                            
                                    <Button Grid.Column="1" 
                                            Text="Eliminar" 
                                            BackgroundColor="Red" 
                                            CornerRadius="5" 
                                            HeightRequest="35"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.DeleteProductCommand}" 
                                            CommandParameter="{Binding .}"/>
                                </Grid>
                                
                            </StackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="No hay productos" HorizontalOptions="Center" VerticalOptions="Center"/>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

        <!-- Floating action button equivalente -->
        <Button Text="+" 
                Command="{Binding AddProductCommand}" 
                FontSize="24"
                WidthRequest="60" 
                HeightRequest="60"
                CornerRadius="30" 
                BackgroundColor="{StaticResource Primary}" 
                TextColor="White"
                HorizontalOptions="End" 
                VerticalOptions="End" 
                Margin="20"/>

    </Grid>

</ContentPage>
