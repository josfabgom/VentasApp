<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:VentasApp.Converters"
             xmlns:models="clr-namespace:VentasApp.Models"
             xmlns:vm="clr-namespace:VentasApp.ViewModels"
             x:Class="VentasApp.Views.TakeOrderPage"
             Title="{Binding Title}">
             
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:ImagePathConverter x:Key="ImagePathConv" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *">
        <!-- Panel Superior Compacto -->
        <VerticalStackLayout Grid.Row="0" Spacing="8" Padding="12" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="Cliente" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
                    <Picker ItemsSource="{Binding AvailableCustomers}" 
                            SelectedItem="{Binding SelectedCustomer}"
                            ItemDisplayBinding="{Binding Name}"
                            Title="Seleccionar..." 
                            FontSize="13"
                            HeightRequest="40"/>
                </VerticalStackLayout>
                
                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Vendedor" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
                    <Picker ItemsSource="{Binding AvailableVendedores}" 
                            SelectedItem="{Binding SelectedVendedor}"
                            ItemDisplayBinding="{Binding Nombre}"
                            Title="Seleccionar..." 
                            FontSize="13"
                            HeightRequest="40"/>
                </VerticalStackLayout>
            </Grid>

            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                <SearchBar Grid.Column="0" 
                           Placeholder="Buscar producto..." 
                           Text="{Binding SearchText}"
                           SearchCommand="{Binding SearchProductCommand}"
                           TextChanged="OnSearchTextChanged"
                           HeightRequest="45"
                           FontSize="14" />
                <Button Grid.Column="1" 
                        Text="📷" 
                        Command="{Binding ScanCommand}" 
                        FontSize="18"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="White"
                        WidthRequest="45" HeightRequest="40" Padding="0" VerticalOptions="Center"/>
            </Grid>

            <!-- Resultados de Búsqueda (Sugerencias) -->
            <CollectionView ItemsSource="{Binding SearchResults}" 
                            IsVisible="{Binding SearchResults.Count, Converter={StaticResource NullToBoolConverter}, ConverterParameter=Inverted}"
                            HeightRequest="120"
                            Margin="0,0,0,5">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Product">
                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="8,4" ColumnSpacing="10">
                            <Label Grid.Column="0" Text="{Binding Barcode}" FontSize="11" TextColor="Gray" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{Binding Name}" FontSize="13" FontAttributes="Bold" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="{Binding Price, StringFormat='{0:C}'}" FontSize="12" VerticalOptions="Center" TextColor="{StaticResource Success}"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TakeOrderViewModel}}, Path=SelectProductCommand}" 
                                                      CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Producto Seleccionado y Cantidad -->
            <Frame BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray800}}" 
                   BorderColor="{StaticResource Secondary}" 
                   Padding="10" 
                   Margin="0,2"
                   IsVisible="{Binding SelectedProduct, Converter={StaticResource NullToBoolConverter}, ConverterParameter=Inverted}">
                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                        <Label Text="{Binding SelectedProduct.Name}" FontAttributes="Bold" FontSize="15" />
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="{Binding SelectedProduct.Price, StringFormat='Prec: {0:C}'}" FontSize="12" />
                            <Label Text="{Binding SelectedProduct.Stock, StringFormat='Stock: {0}'}" FontSize="12" TextColor="{StaticResource Primary}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <HorizontalStackLayout Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" VerticalOptions="Center" Spacing="8">
                        <VerticalStackLayout WidthRequest="70">
                            <Label Text="Cant." FontSize="10" HorizontalOptions="Center"/>
                            <Entry Text="{Binding Quantity}" Keyboard="Numeric" HeightRequest="35" FontSize="14" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                        <Button Text="+" 
                                Command="{Binding AddProductCommand}" 
                                BackgroundColor="{StaticResource Success}"
                                TextColor="White"
                                WidthRequest="45" HeightRequest="35" Padding="0" FontSize="18"/>
                    </HorizontalStackLayout>
                </Grid>
            </Frame>
        </VerticalStackLayout>

        <!-- Detalle del Pedido (Ocupa el resto) -->
        <Grid Grid.Row="1" RowDefinitions="*, Auto" Padding="12,0,12,12">
            <CollectionView Grid.Row="0" ItemsSource="{Binding OrderItems}" SelectionMode="None">
                <CollectionView.Header>
                    <Label Text="Detalle del Pedido" FontAttributes="Bold" FontSize="14" Margin="0,5" TextColor="Gray"/>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="35, *, 60, 40" Padding="0,8" VerticalOptions="Center">
                            <Image Grid.Column="0" 
                                   Source="{Binding Product.ImageUrl, Converter={StaticResource ImagePathConv}}" 
                                   WidthRequest="30" HeightRequest="30" 
                                   Aspect="AspectFill" />
                                   
                            <Label Grid.Column="1" Text="{Binding Product.Name}" FontSize="13" VerticalOptions="Center" Margin="8,0"/>
                            <Label Grid.Column="2" Text="{Binding Quantity, StringFormat='x {0} uds'}" FontSize="12" VerticalOptions="Center" HorizontalOptions="End"/>
                            
                            <Button Grid.Column="3" 
                                    Text="✕"
                                    BackgroundColor="Transparent"
                                    TextColor="Red"
                                    FontAttributes="Bold"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.RemoveProductCommand}"
                                    CommandParameter="{Binding .}"
                                    HeightRequest="30" WidthRequest="30" Padding="0"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                        <Label Text="No hay productos en el pedido" TextColor="Gray" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>

            <!-- Resumen y Botón Final -->
            <VerticalStackLayout Grid.Row="1" Spacing="10" Padding="0,10,0,0">
                <BoxView HeightRequest="1" Color="{StaticResource Gray200}"/>
                <Grid ColumnDefinitions="*, Auto">
                    <Label Grid.Column="0" Text="Total Pedido" VerticalOptions="Center" TextColor="Gray" FontSize="15"/>
                    <Label Grid.Column="1" Text="{Binding TotalAmount, StringFormat='{0:C}'}" 
                           FontSize="20" FontWeight="Bold" Color="{StaticResource Primary}"/>
                </Grid>

                <Button Text="CONFIRMAR PEDIDO" 
                        Command="{Binding SaveOrderCommand}" 
                        CornerRadius="12" 
                        FontAttributes="Bold"
                        HeightRequest="50"
                        BackgroundColor="{StaticResource Primary}" 
                        TextColor="White"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>
